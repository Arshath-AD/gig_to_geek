# ============================================================
# GigToGeek — .gitignore
# ============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.env
.env.*
!.env.example

# ── Node / JS ─────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.pnpm-store/

# ── Build outputs ─────────────────────────────────────────────
dist/
build/
.next/
out/
.expo/
*.tsbuildinfo

# ── Docker ────────────────────────────────────────────────────
docker-compose.override.yml

# ── Database ──────────────────────────────────────────────────
*.sqlite3
*.db
postgres_data/

# ── IDE / OS ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/

# ── Test & Coverage ───────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
